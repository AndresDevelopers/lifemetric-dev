# ==========================================
# ENV_EXAMPLE - lifemetric
# MVP Seguimiento Metabólico
# ==========================================

# 1. Base de Datos Principal (Supabase + Prisma)
# -----------------------------------------------
# Transactional connection pooler (Puerto 6543) - Para consultas generales.
# Reemplazar [PROYECTO], [PASSWORD] y [REGION] con tus datos de Supabase.
DATABASE_URL="postgresql://postgres.[PROYECTO]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (Puerto 5432) - Requerido por Prisma para las migraciones (npx prisma migrate).
DIRECT_URL="postgresql://postgres.[PROYECTO]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase SDK (Client-side) - Requerido para Storage y Auth (Tambien para Desarrollo)
NEXT_PUBLIC_SUPABASE_URL="https://[ID-PROYECTO].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-aqui"
# Supabase Service Role Key (Server-side) - Requerido para operaciones seguras en Server Actions/Auth
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-aqui"



# 2. Redis de Edge y Caché (Upstash) - MANDATORIO (Reglas AIO)
# -------------------------------------------------------------
# Requerido para Rate Limiting (Idempotencia en guardado de datos y WAF).
UPSTASH_REDIS_REST_URL="https://[TU-URL-DE-UPSTASH].upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu-token-seguro-aqui"


# 3. Cloudflare & Seguridad (Turnstile y Purga de Caché)
# -----------------------------------------------------
# Cloudflare Turnstile (CAPTCHA) - MANDATORIO para Login/Registro
# Site Key Pública (Disponible en el dashboard de Cloudflare) (Tambien para Desarrollo)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
# Secret Key Privada (Solo servidor - ¡No exponer!)
TURNSTILE_SECRET_KEY="1x00000000000000000000AA"
# Modo de Turnstile ("invisible" o "normal")
NEXT_PUBLIC_TURNSTILE_MODE="normal"

# Cloudflare Global Settings (Cache Purging & WAF - Reglas Críticas)
CLOUDFLARE_API_TOKEN="..."
CLOUDFLARE_ZONE_ID="..."
CLOUDFLARE_ACCOUNT_ID="..."
CLOUDFLARE_EMAIL="..."


# 4. Observabilidad y Monitoreo (Vercel Agent)
# --------------------------------------------
# Sin variables adicionales requeridas en .env para Vercel Agent.


# 5. Configuración de Aplicación e Internacionalización (Tambien para Desarrollo)
# -----------------------------------------------------
# Nombre a mostrar del dashboard
NEXT_PUBLIC_APP_NAME="MetabolicCare MVP"
# Logo horizontal/oficial (logo + nombre). Si existe, reemplaza el título con icono en la UI.
NEXT_PUBLIC_APP_BRAND_LOGO_URL=""
# Icono cuadrado de la app (solo icono). Se usa donde solo se muestra el icono.
NEXT_PUBLIC_APP_ICON_URL=""
# Favicon oficial de la app. También se usa como imagen por defecto al compartir enlaces.
NEXT_PUBLIC_APP_FAVICON_URL=""
# Final de configuración de aplicación (Detectado automáticamente)
# ------------------------------------------------------------------
# URL base de la aplicación para redirecciones y callbacks
NEXT_PUBLIC_BASE_URL="http://localhost:3000"


# 6. Seguridad y Autenticación - MANDATORIO (Tambien para Desarrollo)
# ----------------------------------------
# Secreto para firma de cookies de sesión (Lifemetric Session)
# IMPORTANTE: Generar uno seguro con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-generado-aqui"

# Clave para encriptación de datos sensibles (opcional)
ENCRYPTION_KEY="..."

# 7. Email transaccional (Resend)
# -------------------------------
# API key privada de Resend
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
# Dominio/verificado remitente en Resend
RESEND_FROM_EMAIL="Lifemetric <no-reply@tu-dominio.com>"


# 8. IA Generativa (Vercel AI Gateway)
# --------------------------------------
# API key del AI Gateway de Vercel (server-side)
AI_GATEWAY_API_KEY="vgw_..."
# Modelo configurable (ejemplo: proveedor/modelo)
AI_GATEWAY_MODEL="google/gemini-2.0-flash-001"


# 9. Anti-malware (VirusTotal)
# ----------------------------
# API key privada de VirusTotal para escanear imágenes/PDF al subirlos.
# Si no se configura o falla la API, la app sigue operando en modo resiliente.
VIRUSTOTAL_API_KEY=""
