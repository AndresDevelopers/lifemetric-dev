generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Paciente {
  paciente_id          String    @id @default(uuid())
  email                String    @unique
  nombre               String
  apellido             String
  password_hash        String
  edad                 Int
  sexo                 String    // 'M' o 'F'
  fecha_nacimiento     DateTime?
  avatar_url           String?
  diagnostico_principal String
  usa_glucometro       Boolean   @default(false)
  medicacion_base      String?
  metas_salud          String?
  peso_inicial         Float?
  estura               Float?
  nivel_actividad      String?
  created_at           DateTime  @default(now())

  sesiones             Sesion[]
  comidas              Comida[]
  glucosas             Glucosa[]
  habitos              Habito[]
}

model Sesion {
  sesion_id   String   @id @default(uuid())
  paciente_id String
  token       String   @unique
  expires_at  DateTime
  created_at  DateTime @default(now())

  paciente    Paciente @relation(fields: [paciente_id], references: [paciente_id], onDelete: Cascade)
}

model Comida {
  comida_id   String   @id @default(uuid())
  paciente_id String
  nombre      String
  calorias    Int?
  carbohidratos Int?
  proteinas   Int?
  grasas      Int?
  fecha       DateTime @default(now())
  notas       String?

  paciente    Paciente @relation(fields: [paciente_id], references: [paciente_id], onDelete: Cascade)
}

model Glucosa {
  glucosa_id  String   @id @default(uuid())
  paciente_id String
  valor       Int
  momento     String   // 'ayunas', 'post-prandial', etc.
  fecha       DateTime @default(now())
  notas       String?

  paciente    Paciente @relation(fields: [paciente_id], references: [paciente_id], onDelete: Cascade)
}

model Habito {
  habito_id   String   @id @default(uuid())
  paciente_id String
  tipo        String   // 'agua', 'ejercicio', 'sueno'
  valor       Float
  unidad      String
  fecha       DateTime @default(now())

  paciente    Paciente @relation(fields: [paciente_id], references: [paciente_id], onDelete: Cascade)
}
